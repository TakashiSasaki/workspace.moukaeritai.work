rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Security helper primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // Locked namespaces for multi-user isolation
    match /users/{userId} {
      // Top level user data holds private tokens like githubToken and julesApiKey
      allow read, write: if isOwner(userId);

      // Dashboards collection nested under user namespace
      match /dashboards/{dashboardId} {
        allow get, create, update, delete: if isOwner(userId) && isValidId(dashboardId);
        allow list: if isOwner(userId);
      }

      // Repository Bindings
      match /repoBindings/{bindingId} {
        allow get, create, update, delete: if isOwner(userId) && isValidId(bindingId);
        allow list: if isOwner(userId);
      }

      // Jules bindings configuration
      match /julesBindings/{bindingId} {
        allow get, create, update, delete: if isOwner(userId) && isValidId(bindingId);
        allow list: if isOwner(userId);
      }

      // ChatGPT context links mapping
      match /chatGptLinks/{linkId} {
        allow get, create, update, delete: if isOwner(userId) && isValidId(linkId);
        allow list: if isOwner(userId);
      }

      // Activity timeline events
      match /timelineEvents/{eventId} {
        allow get, create, update, delete: if isOwner(userId) && isValidId(eventId);
        allow list: if isOwner(userId);
      }

      // Jules Sessions
      match /julesSessions/{sessionId} {
        allow get, create, update, delete: if isOwner(userId) && isValidId(sessionId);
        allow list: if isOwner(userId);
      }

      // Jules Activities transcripts
      match /julesActivities/{activityId} {
        allow get, create, update, delete: if isOwner(userId) && isValidId(activityId);
        allow list: if isOwner(userId);
      }
    }
  }
}
